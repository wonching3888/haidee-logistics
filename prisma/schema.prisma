// ─── Driver Expense Module ─────────────────────────────────────────────────────

model UnloadingRateConfig {
  id         String   @id @default(cuid())
  market     String   @unique
  smallCrate Float    @default(0)
  largeCrate Float    @default(0)
  box        Float    @default(0)
  kpbSmall   Float    @default(0)
  kpbLarge   Float    @default(0)
  kpbBox     Float    @default(0)
  kpbMode              String   @default("per_crate")
  unloadMode           String   @default("per_crate")
  perTripSmallTruck    Float?
  perTripLargeTruck    Float?
  thirdPartyFlatUnload Float?
  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())

  @@map("unloading_rate_configs")
}

model CrateLoadingRateConfig {
  id         String   @id @default(cuid())
  market     String   @unique
  smallTruck Float    @default(0)
  largeTruck Float    @default(0)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@map("crate_loading_rate_configs")
}

model UnloadingFee {
  id                String   @id @default(cuid())
  tripId            String   @map("trip_id")
  tripDate          DateTime @map("trip_date") @db.Date
  lorry             String
  driver            String
  route             String
  market            String
  storeCode         String?  @map("store_code")
  smallCrateQty     Int      @default(0) @map("small_crate_qty")
  largeCrateQty     Int      @default(0) @map("large_crate_qty")
  boxQty            Int      @default(0) @map("box_qty")
  unloadFee         Float    @default(0) @map("unload_fee")
  kpbFee            Float    @default(0) @map("kpb_fee")
  unloadFeeOverride Float?   @map("unload_fee_override")
  kpbFeeOverride    Float?   @map("kpb_fee_override")
  isKpbExempt       Boolean  @default(false) @map("is_kpb_exempt")
  tripLevelNote     String?  @map("trip_level_note")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([tripId, market])
  @@index([tripId])
  @@index([tripDate])
  @@map("unloading_fees")
}

model CrateLoadingFee {
  id                 String   @id @default(cuid())
  tripId             String   @map("trip_id")
  tripDate           DateTime @map("trip_date") @db.Date
  lorry              String
  driver             String
  route              String
  market             String
  truckSize          String   @map("truck_size")
  loadingFee         Float    @default(0) @map("loading_fee")
  loadingFeeOverride Float?   @map("loading_fee_override")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([tripId])
  @@index([tripDate])
  @@map("crate_loading_fees")
}

model DriverVoucher {
  id                 String   @id @default(cuid())
  voucherNo          String   @unique @map("voucher_no")
  tripId             String   @map("trip_id")
  tripSource         String   @default("dispatch") @map("tripSource")
  tripDate           DateTime @map("trip_date") @db.Date
  lorry              String
  driverName         String   @map("driver_name")
  route              String
  chopBorderAmt      Float?   @map("chop_border_amt")
  chopBorderActual   Float?   @map("chop_border_actual")
  parkingAmt         Float?   @map("parking_amt")
  parkingActual      Float?   @map("parking_actual")
  kpbAmt             Float?   @map("kpb_amt")
  kpbActual          Float?   @map("kpb_actual")
  fishCheckAmt       Float?   @map("fish_check_amt")
  fishCheckActual    Float?   @map("fish_check_actual")
  upahTurunAmt       Float?   @map("upah_turun_amt")
  upahTurunActual    Float?   @map("upah_turun_actual")
  upahNaikTongAmt    Float?   @map("upah_naik_tong_amt")
  upahNaikTongActual Float?   @map("upah_naik_tong_actual")
  minyakMotoEnabled  Boolean  @default(false) @map("minyak_moto_enabled")
  minyakMotoAmt      Float    @default(8) @map("minyak_moto_amt")
  minyakMotoActual   Float?   @map("minyak_moto_actual")
  otherActual        Float?   @map("other_actual")
  duitJalan          Float?   @map("duit_jalan")
  belanja            Float?   @map("belanja")
  baki               Float?   @map("baki")
  status             String   @default("draft")
  clerkSubmittedAt   DateTime? @map("clerk_submitted_at")
  clerkSubmittedBy   String?  @map("clerk_submitted_by")
  clerkConfirmedAt   DateTime? @map("clerk_confirmed_at")
  clerkConfirmedBy   String?  @map("clerk_confirmed_by")
  clerkFlaggedAt     DateTime? @map("clerk_flagged_at")
  clerkFlaggedBy     String?  @map("clerk_flagged_by")
  reviewedAt         DateTime? @map("reviewed_at")
  reviewedBy         String?  @map("reviewed_by")
  rejectedAt         DateTime? @map("rejected_at")
  rejectedBy         String?  @map("rejected_by")
  costAppliedAt      DateTime? @map("cost_applied_at")
  clerkNote          String?  @map("clerk_note")
  reviewNote         String?  @map("review_note")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  changeLogs DriverVoucherChangeLog[]
  marketActuals DriverVoucherMarketActual[]

  @@unique([tripId, tripSource])
  @@index([status, tripDate(sort: Desc)])
  @@index([tripDate, lorry])
  @@index([tripDate, driverName])
  @@index([tripDate])
  @@index([tripSource])
  @@map("driver_vouchers")
}

model DriverVoucherChangeLog {
  id        String   @id @default(cuid())
  voucherId String   @map("voucher_id")
  eventType String   @map("event_type")
  field     String?
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  changedBy String?  @map("changed_by")
  changedAt DateTime @default(now()) @map("changed_at")
  reason    String?

  voucher DriverVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@index([changedAt])
  @@map("driver_voucher_change_logs")
}

model DriverVoucherMarketActual {
  id            String   @id @default(cuid())
  voucherId     String   @map("voucher_id")
  feeType       String   @map("fee_type")
  displayMarket String   @map("display_market")
  amount        Float?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  voucher DriverVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([voucherId, feeType, displayMarket])
  @@index([voucherId])
  @@map("driver_voucher_market_actuals")
}
