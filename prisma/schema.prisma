// ─── Partner freight (logistics partner per-trip invoices, e.g. TAWAKAR SKTN) ─

model PartnerFreightRate {
  id              String   @id @default(uuid()) @db.Uuid
  crateType       String   @unique @map("crate_type")
  billToShipperId String   @map("bill_to_shipper_id") @db.Uuid
  unitRateMyr     Decimal  @map("unit_rate_myr") @db.Decimal(10, 2)
  taxCode         String   @default("ESV-6") @map("tax_code")
  taxRate         Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 4)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  billToShipper Shipper @relation("PartnerFreightBillTo", fields: [billToShipperId], references: [id])

  @@map("partner_freight_rates")
}

model PartnerTripInvoice {
  id              String   @id @default(uuid()) @db.Uuid
  invoiceNo       String   @unique @map("invoice_no")
  tripDate        DateTime @map("trip_date") @db.Date
  truckId         String   @map("truck_id") @db.Uuid
  marketId        String   @map("market_id") @db.Uuid
  billToShipperId String   @map("bill_to_shipper_id") @db.Uuid
  crateType       String   @map("crate_type")
  quantity        Int
  unitRateMyr     Decimal  @map("unit_rate_myr") @db.Decimal(10, 2)
  amountMyr       Decimal  @map("amount_myr") @db.Decimal(10, 2)
  taxCode         String   @map("tax_code")
  taxRate         Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 4)
  createdAt       DateTime @default(now()) @map("created_at")

  truck         Truck   @relation(fields: [truckId], references: [id])
  market        Market  @relation(fields: [marketId], references: [id])
  billToShipper Shipper @relation("PartnerTripBillTo", fields: [billToShipperId], references: [id])

  @@unique([tripDate, truckId, marketId, crateType])
  @@map("partner_trip_invoices")
}

// ─── Crate return monthly billing (customer-owned empty crates, HAIDEE) ─────

model CrateReturnFreightRate {
  id                String   @id @default(uuid()) @db.Uuid
  crateType         String   @unique @map("crate_type")
  billToShipperId   String   @map("bill_to_shipper_id") @db.Uuid
  freightRateMyr    Decimal  @map("freight_rate_myr") @db.Decimal(10, 2)
  collectionRateMyr Decimal  @map("collection_rate_myr") @db.Decimal(10, 2)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")

  billToShipper Shipper @relation("CrateReturnFreightBillTo", fields: [billToShipperId], references: [id])

  @@map("crate_return_freight_rates")
}

model CrateReturnMonthlyInvoice {
  id                  String   @id @default(uuid()) @db.Uuid
  invoiceNo           String   @unique @map("invoice_no")
  yearMonth           String   @map("year_month")
  billToShipperId     String   @map("bill_to_shipper_id") @db.Uuid
  crateType           String   @map("crate_type")
  quantity            Int
  freightRateMyr      Decimal  @map("freight_rate_myr") @db.Decimal(10, 2)
  collectionRateMyr   Decimal  @map("collection_rate_myr") @db.Decimal(10, 2)
  freightAmountMyr    Decimal  @map("freight_amount_myr") @db.Decimal(10, 2)
  collectionAmountMyr Decimal  @map("collection_amount_myr") @db.Decimal(10, 2)
  totalAmountMyr      Decimal  @map("total_amount_myr") @db.Decimal(10, 2)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  billToShipper Shipper                         @relation("CrateReturnMonthlyBillTo", fields: [billToShipperId], references: [id])
  lines         CrateReturnMonthlyInvoiceLine[]

  @@unique([yearMonth, billToShipperId, crateType])
  @@map("crate_return_monthly_invoices")
}

model CrateReturnMonthlyInvoiceLine {
  id                  String @id @default(uuid()) @db.Uuid
  invoiceId           String @map("invoice_id") @db.Uuid
  marketId            String @map("market_id") @db.Uuid
  quantity            Int
  freightAmountMyr    Decimal @map("freight_amount_myr") @db.Decimal(10, 2)
  collectionAmountMyr Decimal @map("collection_amount_myr") @db.Decimal(10, 2)

  invoice CrateReturnMonthlyInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  market  Market                    @relation(fields: [marketId], references: [id])

  @@unique([invoiceId, marketId])
  @@map("crate_return_monthly_invoice_lines")
}

model MonthlyInvoiceExtraCharge {
  id          String   @id @default(uuid()) @db.Uuid
  year        Int
  month       Int
  mode        String
  customerId  String   @map("customer_id") @db.Uuid
  description String
  amount      Decimal  @db.Decimal(10, 2)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([year, month, mode, customerId])
  @@map("monthly_invoice_extra_charges")
}

