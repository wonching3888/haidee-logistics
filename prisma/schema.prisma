// ─── Thai cost (Phase 2 stage 1: Sadao labor + handling) ─────────────────────

/// Monthly-salaried Thai workers (named profiles; few people).
model ThaiMonthlyWorker {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  station           String // SADAO | SONGKHLA | PATTANI
  monthlyWage       Decimal  @map("monthly_wage") @db.Decimal(12, 2)
  lunchAllowance    Decimal  @default(1000) @map("lunch_allowance") @db.Decimal(12, 2)
  fuelAllowance     Decimal  @default(0) @map("fuel_allowance") @db.Decimal(12, 2)
  rentRoomAllowance Decimal  @default(0) @map("rent_room_allowance") @db.Decimal(12, 2)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([station, active])
  @@map("thai_monthly_workers")
}

/// Monthly roster headcount for daily-wage labor (no named profiles).
/// Used for fixed LUNCH allowance = rosterCount × lunch rate (not pro-rated by attendance days).
model ThaiDailyLaborMonthlyRoster {
  id          String   @id @default(uuid()) @db.Uuid
  yearMonth   String   @map("year_month")
  station     String // SADAO | SONGKHLA | PATTANI
  rosterCount Int      @map("roster_count")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([yearMonth, station])
  @@map("thai_daily_labor_monthly_rosters")
}

/// Daily-wage foreign labor attendance (headcount only, no names).
/// Cost modes:
/// - Sadao: attendanceCount × dailyWage (totalWagePaid is null)
/// - Songkhla: totalWagePaid when set (mixed unit rates; clerk enters day total)
model ThaiDailyLaborAttendance {
  id               String   @id @default(uuid()) @db.Uuid
  date             DateTime @db.Date
  station          String // SADAO | SONGKHLA | PATTANI
  attendanceCount  Int      @map("attendance_count")
  dailyWage        Decimal  @map("daily_wage") @db.Decimal(12, 2)
  /// When set, day cost = this amount (ignores attendanceCount × dailyWage).
  totalWagePaid    Decimal? @map("total_wage_paid") @db.Decimal(12, 2)
  notes            String?
  createdBy        String   @map("created_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([date, station])
  @@index([station, date])
  @@map("thai_daily_labor_attendance")
}

/// Thai driver master (base wage + daily trip counts).
model ThaiDriver {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  baseWage  Decimal  @map("base_wage") @db.Decimal(12, 2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trips        ThaiDriverTripDaily[]
  vehicleTrips ThaiVehicleTripDaily[]

  @@index([active])
  @@map("thai_drivers")
}

/// Daily trip counts per Thai driver (Songkhla / Pattani commission).
/// Kept as a driver-commission aggregate (formal drivers only).
/// Per-trip plate-level rows live in ThaiVehicleTripDaily.
model ThaiDriverTripDaily {
  id                String   @id @default(uuid()) @db.Uuid
  date              DateTime @db.Date
  driverId          String   @map("driver_id") @db.Uuid
  songkhlaTripCount Int      @default(0) @map("songkhla_trip_count")
  pattaniTripCount  Int      @default(0) @map("pattani_trip_count")
  notes             String?
  createdBy         String   @map("created_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  /** Linked THB Cash Book PV (6500 trip wages); null = unsettled. */
  cashBookPaymentVoucherId String? @unique @map("cash_book_payment_voucher_id") @db.Uuid

  driver ThaiDriver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  cashBookPaymentVoucher CashBookPaymentVoucher? @relation(fields: [cashBookPaymentVoucherId], references: [id], onDelete: SetNull)

  @@unique([date, driverId])
  @@index([date])
  @@map("thai_driver_trip_daily")
}

/// One row per Thai-segment vehicle trip (Excel trip line; not driver-day aggregate).
/// Formal drivers have driverId; rented/unknown have driverId=null and notes like RENTED:BANHENG.
model ThaiVehicleTripDaily {
  id         String   @id @default(uuid()) @db.Uuid
  date       DateTime @db.Date
  truckPlate String   @map("truck_plate")
  driverId   String?  @map("driver_id") @db.Uuid
  station    String // SONGKHLA | PATTANI
  tongQty    Int      @default(0) @map("tong_qty")
  boxQty     Int      @default(0) @map("box_qty")
  notes      String?
  createdBy  String   @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  driver ThaiDriver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([truckPlate, date])
  @@index([station, date])
  @@index([driverId, date])
  @@map("thai_vehicle_trip_daily")
}

/// Current Thai cost rate defaults (future records / unlocked months).
model ThaiCostRateSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Decimal  @default(0) @db.Decimal(12, 4)
  /// Non-numeric settings (e.g. large_tong_type_codes JSON array).
  valueText String?  @map("value_text")
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("thai_cost_rate_settings")
}

/// Locked monthly rates for handling + driver trip commission (prevents historical drift).
model ThaiCostMonthlyRateSnapshot {
  id                      String   @id @default(uuid()) @db.Uuid
  yearMonth               String   @unique @map("year_month")
  handlingSmallWeekday    Decimal  @map("handling_small_weekday") @db.Decimal(12, 4)
  handlingSmallHoliday    Decimal  @map("handling_small_holiday") @db.Decimal(12, 4)
  handlingLargeWeekday    Decimal  @map("handling_large_weekday") @db.Decimal(12, 4)
  handlingLargeHoliday    Decimal  @map("handling_large_holiday") @db.Decimal(12, 4)
  driverTripSongkhla      Decimal  @map("driver_trip_songkhla") @db.Decimal(12, 4)
  driverTripPattani       Decimal  @map("driver_trip_pattani") @db.Decimal(12, 4)
  pattaniContractorCrate  Decimal  @default(20) @map("pattani_contractor_crate") @db.Decimal(12, 4)
  pattaniContractorBox    Decimal  @default(5) @map("pattani_contractor_box") @db.Decimal(12, 4)
  pattaniSakriCrate       Decimal  @default(2.2) @map("pattani_sakri_crate") @db.Decimal(12, 4)
  /// Songkhla handling: unified crate/box rates (null = legacy Sadao split on locked months).
  songkhlaCrateRate       Decimal? @map("songkhla_crate_rate") @db.Decimal(12, 4)
  songkhlaBoxRate         Decimal? @map("songkhla_box_rate") @db.Decimal(12, 4)
  /// JSON array of tong type codes treated as large for Thai cost only.
  largeTongTypeCodes      String   @default("[\"VIO\",\"BS\",\"GKS\"]") @map("large_tong_type_codes")
  snapshotAt              DateTime @map("snapshot_at")
  createdBy               String   @map("created_by") @db.Uuid

  @@map("thai_cost_monthly_rate_snapshots")
}

/// External rented vehicle trips (not company Thai drivers; no base wage / trip commission).
model ThaiRentedVehicleTrip {
  id         String   @id @default(uuid()) @db.Uuid
  date       DateTime @db.Date
  station    String // SONGKHLA | PATTANI
  driverName String   @map("driver_name")
  truckPlate String?  @map("truck_plate")
  tripCost   Decimal  @map("trip_cost") @db.Decimal(12, 2)
  notes      String?
  createdBy  String   @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([station, date])
  @@map("thai_rented_vehicle_trips")
}

/// Locked monthly Thai-segment internal cost (MYR) by pickup location.
model ThaiSegmentInternalCostSnapshot {
  id                 String   @id @default(uuid()) @db.Uuid
  yearMonth          String   @map("year_month")
  pickupLocation     String   @map("pickup_location") // SONGKHLA | PATTANI
  totalAmountMyr     Decimal  @map("total_amount_myr") @db.Decimal(14, 2)
  ratesUsedSnapshot  Json     @map("rates_used_snapshot")
  snapshotAt         DateTime @map("snapshot_at")
  createdBy          String   @map("created_by") @db.Uuid

  @@unique([yearMonth, pickupLocation])
  @@map("thai_segment_internal_cost_snapshots")
}

/// Thai public holidays (manual calendar; Sundays are auto holiday-rate without rows here).
model ThaiPublicHoliday {
  id        String   @id @default(uuid()) @db.Uuid
  date      DateTime @unique @db.Date
  name      String
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@map("thai_public_holidays")
}

/// Sadao daily crate handling (commission rates from settings / monthly snapshot).
model SadaoCrateHandlingDaily {
  id                   String   @id @default(uuid()) @db.Uuid
  date                 DateTime @unique @db.Date
  smallCrateTotalQty   Int      @map("small_crate_total_qty")
  largeCrateTotalQty   Int      @map("large_crate_total_qty")
  boxTotalQty          Int      @default(0) @map("box_total_qty")
  smallCrateNoCheckQty Int      @default(0) @map("small_crate_no_check_qty")
  largeCrateNoCheckQty Int      @default(0) @map("large_crate_no_check_qty")
  boxNoCheckQty        Int      @default(0) @map("box_no_check_qty")
  notes                String?
  createdBy            String   @map("created_by") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  /** Linked THB Cash Book PV (6502 handling commission only; excludes other expenses). */
  cashBookPaymentVoucherId String? @unique @map("cash_book_payment_voucher_id") @db.Uuid

  otherExpenses SadaoHandlingOtherExpense[]
  cashBookPaymentVoucher CashBookPaymentVoucher? @relation(fields: [cashBookPaymentVoucherId], references: [id], onDelete: SetNull)

  @@map("sadao_crate_handling_daily")
}

/// Free-form other expenses on a Sadao handling day (clerk-entered).
model SadaoHandlingOtherExpense {
  id              String   @id @default(uuid()) @db.Uuid
  handlingDailyId String   @map("handling_daily_id") @db.Uuid
  handlingDaily   SadaoCrateHandlingDaily @relation(fields: [handlingDailyId], references: [id], onDelete: Cascade)
  description     String
  amountThb       Decimal  @map("amount_thb") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([handlingDailyId])
  @@map("sadao_handling_other_expenses")
}

/// Songkhla daily crate handling.
/// manualQty=false: billing/display follow live dispatch totals.
/// manualQty=true: stored small/large/box totals are locked billable qty.
model SongkhlaCrateHandlingDaily {
  id                 String   @id @default(uuid()) @db.Uuid
  date               DateTime @unique @db.Date
  smallCrateTotalQty Int      @map("small_crate_total_qty")
  largeCrateTotalQty Int      @map("large_crate_total_qty")
  boxTotalQty        Int      @default(0) @map("box_total_qty")
  manualQty          Boolean  @default(false) @map("manual_qty")
  notes              String?
  createdBy          String   @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  /** Linked THB Cash Book PV (6502 handling commission). */
  cashBookPaymentVoucherId String? @unique @map("cash_book_payment_voucher_id") @db.Uuid

  cashBookPaymentVoucher CashBookPaymentVoucher? @relation(fields: [cashBookPaymentVoucherId], references: [id], onDelete: SetNull)

  @@map("songkhla_crate_handling_daily")
}

/// Pattani daily handling: one entry drives contractor fee + SAKRI commission.
/// manualQty=false: follow live dispatch; manualQty=true: stored crate/box locked.
model PattaniCrateHandlingDaily {
  id        String   @id @default(uuid()) @db.Uuid
  date      DateTime @unique @db.Date
  crateQty  Int      @map("crate_qty")
  boxQty    Int      @default(0) @map("box_qty")
  manualQty Boolean  @default(false) @map("manual_qty")
  notes     String?
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  /** Linked THB Cash Book PV (6502 handling commission). */
  cashBookPaymentVoucherId String? @unique @map("cash_book_payment_voucher_id") @db.Uuid

  cashBookPaymentVoucher CashBookPaymentVoucher? @relation(fields: [cashBookPaymentVoucherId], references: [id], onDelete: SetNull)

  @@map("pattani_crate_handling_daily")
}

/// Cash Book payment voucher header (THB or MYR book).
model CashBookPaymentVoucher {
  id             String    @id @default(uuid()) @db.Uuid
  voucherNo      String    @unique @map("voucher_no")
  book           String // THB | MYR
  voucherDate    DateTime  @map("voucher_date") @db.Date
  paidTo         String    @map("paid_to")
  paymentMethod  String    @map("payment_method") // CASH | TRANSFER | CHEQUE
  checkNo        String?   @map("check_no")
  checkDate      DateTime? @map("check_date") @db.Date
  dueDate        DateTime? @map("due_date") @db.Date
  status         String    @default("draft") // draft | confirmed
  confirmedAt    DateTime? @map("confirmed_at")
  confirmedBy    String?   @map("confirmed_by") @db.Uuid
  payeeSignature String?   @map("payee_signature")
  preparedBy     String?   @map("prepared_by")
  approvedBy     String?   @map("approved_by")
  totalAmount    Decimal   @map("total_amount") @db.Decimal(14, 2)
  createdBy      String    @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  lines CashBookPaymentVoucherLine[]
  driverVoucher DriverVoucher?
  sadaoHandlingDaily SadaoCrateHandlingDaily?
  songkhlaHandlingDaily SongkhlaCrateHandlingDaily?
  pattaniHandlingDaily PattaniCrateHandlingDaily?
  thaiDriverTripDaily ThaiDriverTripDaily?

  @@index([voucherDate])
  @@index([book])
  @@index([status])
  @@map("cash_book_payment_vouchers")
}

model CashBookPaymentVoucherLine {
  id          String  @id @default(uuid()) @db.Uuid
  voucherId   String  @map("voucher_id") @db.Uuid
  lineOrder   Int     @map("line_order")
  accountCode String  @map("account_code")
  accountName String  @map("account_name")
  particulars String?
  amount      Decimal @db.Decimal(14, 2)

  voucher CashBookPaymentVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@map("cash_book_payment_voucher_lines")
}

/// Cash Book receipt voucher (inflow; THB or MYR book).
/// Header accountCode/accountName/amount/notes are cache mirrors of lineOrder=1.
model CashBookReceiptVoucher {
  id            String    @id @default(uuid()) @db.Uuid
  voucherNo     String    @unique @map("voucher_no")
  book          String // THB | MYR
  voucherDate   DateTime  @map("voucher_date") @db.Date
  receivedFrom  String    @map("received_from")
  accountCode   String    @map("account_code")
  accountName   String    @map("account_name")
  amount        Decimal   @db.Decimal(14, 2)
  notes         String?
  status        String    @default("draft") // draft | confirmed
  confirmedAt   DateTime? @map("confirmed_at")
  confirmedBy   String?   @map("confirmed_by") @db.Uuid
  preparedBy    String?   @map("prepared_by")
  approvedBy    String?   @map("approved_by")
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  lines CashBookReceiptVoucherLine[]

  @@index([voucherDate])
  @@index([book])
  @@index([status])
  @@map("cash_book_receipt_vouchers")
}

model CashBookReceiptVoucherLine {
  id          String  @id @default(uuid()) @db.Uuid
  voucherId   String  @map("voucher_id") @db.Uuid
  lineOrder   Int     @map("line_order")
  accountCode String  @map("account_code")
  accountName String  @map("account_name")
  particulars String?
  amount      Decimal @db.Decimal(14, 2)

  voucher CashBookReceiptVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([voucherId, lineOrder])
  @@index([voucherId])
  @@map("cash_book_receipt_voucher_lines")
}

/// Audited opening-balance adjustments for Cash Book ledgers (default 0 until set).
model CashBookOpeningBalanceAdjustment {
  id              String   @id @default(uuid()) @db.Uuid
  book            String // THB | MYR
  previousAmount  Decimal  @map("previous_amount") @db.Decimal(14, 2)
  newAmount       Decimal  @map("new_amount") @db.Decimal(14, 2)
  notes           String
  createdBy       String   @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([book, createdAt])
  @@map("cash_book_opening_balance_adjustments")
}
