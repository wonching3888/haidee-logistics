}

model TongExport {
  id                String   @id @default(uuid()) @db.Uuid
  exportNo          String?  @map("export_no")
  date              DateTime @db.Date
  thVehiclePlate    String   @map("th_vehicle_plate")
  areaNote          String?  @map("area_note")
