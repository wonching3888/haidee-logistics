generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users (synced with Supabase Auth) ───────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  role String   @default("clerk") // admin | clerk | thai_accounting | my_accounting | viewer (legacy: accounting, owner→viewer)
  language  String   @default("zh") // zh | th — UI local language (English always shown)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  inboundSessions InboundSession[]
  dispatchOrders  DispatchOrder[]
  charterTrips    CharterTrip[]
  tongImports     TongImport[]
  tongExports     TongExport[]
  tongStockAdjustments TongStockAdjustment[]
  inboundChangeLogs InboundChangeLog[]

  @@map("users")
}

// ─── Master Data ─────────────────────────────────────────────────────────────

model Market {
  id           String   @id @default(uuid()) @db.Uuid
  code         String   @unique
  name         String
  state        String?
  displayOrder Int?     @map("display_order")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  stalls       Stall[]
  freightRates FreightRate[]
  consigneeFreightRates ConsigneeFreightRate[]
  tongImports  TongImport[]
  partnerTripInvoices PartnerTripInvoice[]
  crateReturnMonthlyInvoiceLines CrateReturnMonthlyInvoiceLine[]

  tollFee              Decimal? @map("toll_fee") @db.Decimal(10, 2)
  loadUnloadPerCrate   Decimal? @map("load_unload_per_crate") @db.Decimal(10, 2)
  crateRentalPerCrate  Decimal? @map("crate_rental_per_crate") @db.Decimal(10, 2)

  @@map("markets")
}

model CrateAgent {
  id       String   @id @default(uuid()) @db.Uuid
  name     String
  whatsapp String?
  markets  String[]
  active   Boolean  @default(true)

  @@map("crate_agents")
}

model RouteMaster {
  id                String   @id @default(uuid()) @db.Uuid
  code              String   @unique
  name              String
  markets           String[]
  sadooMileageKm    Decimal? @map("sadoo_mileage_km") @db.Decimal(10, 2)
  tollFee           Decimal? @map("toll_fee") @db.Decimal(10, 2)
  tollFeeClass2     Decimal? @map("toll_fee_class2") @db.Decimal(10, 2)
  tollFeeClass3     Decimal? @map("toll_fee_class3") @db.Decimal(10, 2)
  fishCheckingFee   Decimal? @map("fish_checking_fee") @db.Decimal(10, 2)
  kpbFee            Decimal? @map("kpb_fee") @db.Decimal(10, 2)
  parkingFee        Decimal? @map("parking_fee") @db.Decimal(10, 2)
  driverAllowance   Decimal? @map("driver_allowance") @db.Decimal(10, 2)
  displayOrder      Int?     @map("display_order")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("route_masters")
}

model TongType {
  id             String  @id @default(uuid()) @db.Uuid
  code           String  @unique
  name           String
  trackInventory Boolean @default(true) @map("track_inventory")
  isBox          Boolean @default(false) @map("is_box")
  displayOrder   Int?    @map("display_order")
  active         Boolean @default(true)
  /// When false, tong type is only selectable on empty-crate import (e.g. SKTN).
  showInInbound  Boolean @default(true) @map("show_in_inbound")

  shippers              Shipper[]
  shipperStallDefaults  ShipperStallDefault[]
  inboundLines          InboundLine[]
  inboundLinesOriginal  InboundLine[]         @relation("OriginalTongType")
  tongImports           TongImport[]
  tongExports           TongExport[]
  tongStockAdjustments  TongStockAdjustment[]
  customerCrateStock    CustomerCrateStock[]
  customerCrateLedger   CustomerCrateLedger[]
  charterTripLines      CharterTripLine[]

  @@map("tong_types")
}

model Shipper {
  id               String   @id @default(uuid()) @db.Uuid
  code             String   @unique
  name             String
  nameTh           String?  @map("name_th")
  phone            String?
  lineId           String?  @map("line_id")
  location         String?
  pickupLocation   String   @default("SADAO") @map("pickup_location")
  defaultTongTypeId String? @map("default_tong_type_id") @db.Uuid
  paymentParty     String   @default("shipper") @map("payment_party")
  company          String   @default("haidee")
  currency         String   @default("THB")
  /// operational | logistics_partner — partners are bill-to only, excluded from inbound.
  shipperKind      String   @default("operational") @map("shipper_kind")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")

  defaultTongType      TongType?             @relation(fields: [defaultTongTypeId], references: [id])
  stalls               ShipperStallDefault[]
  freightRates         FreightRate[]
  paymentRelations     PaymentRelation[]
  thVehicles           ThVehicle[]
  inboundSessions      InboundSession[]
  tongExports          TongExport[]
  customerCrateStock   CustomerCrateStock[]
  customerCrateLedger  CustomerCrateLedger[]
  charterTrips         CharterTrip[]
  partnerFreightRates  PartnerFreightRate[]  @relation("PartnerFreightBillTo")
  partnerTripInvoices  PartnerTripInvoice[]  @relation("PartnerTripBillTo")
  crateReturnFreightRates   CrateReturnFreightRate[]   @relation("CrateReturnFreightBillTo")
  crateReturnMonthlyInvoices CrateReturnMonthlyInvoice[] @relation("CrateReturnMonthlyBillTo")

  @@map("shippers")
}

model Stall {
  id          String  @id @default(uuid()) @db.Uuid
  code        String
  name        String?
  marketId    String? @map("market_id") @db.Uuid
  consigneeId String? @map("consignee_id") @db.Uuid
  active      Boolean @default(true)

  market               Market?               @relation(fields: [marketId], references: [id])
  consignee            Consignee?            @relation(fields: [consigneeId], references: [id])
  shipperStallDefaults ShipperStallDefault[]
  inboundLines         InboundLine[]
  inboundLinesOriginal InboundLine[]         @relation("OriginalStall")

  @@map("stalls")
}

model ShipperStallDefault {
  id         String @id @default(uuid()) @db.Uuid
  shipperId  String @map("shipper_id") @db.Uuid
  stallId    String @map("stall_id") @db.Uuid
  tongTypeId String @map("tong_type_id") @db.Uuid

  shipper  Shipper  @relation(fields: [shipperId], references: [id])
  stall    Stall    @relation(fields: [stallId], references: [id])
  tongType TongType @relation(fields: [tongTypeId], references: [id])

  @@unique([shipperId, stallId])
  @@map("shipper_stall_defaults")
}

model FreightRate {
  id            String   @id @default(uuid()) @db.Uuid
  shipperId     String   @map("shipper_id") @db.Uuid
  marketId      String   @map("market_id") @db.Uuid
  rateTong      Decimal? @map("rate_tong") @db.Decimal(10, 2)
  rateBox       Decimal? @map("rate_box") @db.Decimal(10, 2)
  rateTongThai  Decimal? @map("rate_tong_thai") @db.Decimal(10, 2)
  rateBoxThai   Decimal? @map("rate_box_thai") @db.Decimal(10, 2)
  isWtl         Boolean  @default(false) @map("is_wtl")
  sstApplicable Boolean  @default(false) @map("sst_applicable")
  currency      String   @default("MYR")
  effectiveDate DateTime @default(now()) @map("effective_date") @db.Date

  shipper Shipper @relation(fields: [shipperId], references: [id])
  market  Market  @relation(fields: [marketId], references: [id])

  @@index([shipperId])
  @@unique([shipperId, marketId, effectiveDate])
  @@map("freight_rates")
}

model Consignee {
  id             String   @id @default(uuid()) @db.Uuid
  code           String   @unique
  name           String
  billingCompany String   @default("haidee") @map("billing_company")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  freightRates     ConsigneeFreightRate[]
  paymentRelations PaymentRelation[]
  secondaryPaymentRelations PaymentRelation[] @relation("SecondaryPaymentConsignee")
  stalls           Stall[]
  inboundLines     InboundLine[]
  dualPaymentWtlInboundLines InboundLine[] @relation("InboundLineDualPaymentWtlConsignee")

  @@map("consignees")
}

model ConsigneeFreightRate {
  id            String   @id @default(uuid()) @db.Uuid
  consigneeId   String   @map("consignee_id") @db.Uuid
  marketId      String   @map("market_id") @db.Uuid
  rateTong      Decimal? @map("rate_tong") @db.Decimal(10, 2)
  rateBox       Decimal? @map("rate_box") @db.Decimal(10, 2)
  rateTongThai  Decimal? @map("rate_tong_thai") @db.Decimal(10, 2)
  rateBoxThai   Decimal? @map("rate_box_thai") @db.Decimal(10, 2)
  sstApplicable Boolean  @default(false) @map("sst_applicable")
  permitPerTrip Decimal? @map("permit_per_trip") @db.Decimal(10, 2)
  effectiveDate DateTime @map("effective_date") @db.Date

  consignee Consignee @relation(fields: [consigneeId], references: [id], onDelete: Cascade)
  market    Market    @relation(fields: [marketId], references: [id])

  @@index([consigneeId])
  @@unique([consigneeId, marketId, effectiveDate])
  @@map("consignee_freight_rates")
}

model PaymentRelation {
  id                   String   @id @default(uuid()) @db.Uuid
  shipperId            String   @map("shipper_id") @db.Uuid
  consigneeId          String   @map("consignee_id") @db.Uuid
  paymentMode          String   @map("payment_mode")
  dualPayment          Boolean  @default(false) @map("dual_payment")
  secondaryConsigneeId String?  @map("secondary_consignee_id") @db.Uuid
  secondaryPaymentMode String?  @map("secondary_payment_mode")

  shipper            Shipper    @relation(fields: [shipperId], references: [id], onDelete: Cascade)
  consignee          Consignee  @relation(fields: [consigneeId], references: [id], onDelete: Cascade)
  secondaryConsignee Consignee? @relation("SecondaryPaymentConsignee", fields: [secondaryConsigneeId], references: [id])

  @@index([shipperId])
  @@unique([shipperId, consigneeId])
  @@map("payment_relations")
}

model ExchangeRate {
  id        String   @id @default(uuid()) @db.Uuid
  yearMonth String   @unique @map("year_month")
  rate      Decimal  @default(8.20) @db.Decimal(10, 4)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("exchange_rates")
}

model FuelPrice {
  id          String   @id @default("default")
  myrPerLiter Decimal  @default(2.05) @map("myr_per_liter") @db.Decimal(10, 4)
  thbPerLiter Decimal  @default(35.00) @map("thb_per_liter") @db.Decimal(10, 4)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("fuel_prices")
}

model FreightOperationalSettings {
  id                      String   @id @default("default")
  mcThirdPartyRateTong    Decimal? @map("mc_third_party_rate_tong") @db.Decimal(10, 2)
  mcThirdPartyRateBox     Decimal? @map("mc_third_party_rate_box") @db.Decimal(10, 2)
  mySegmentRateTong       Decimal? @map("my_segment_rate_tong") @db.Decimal(10, 2)
  mySegmentRateBox        Decimal? @map("my_segment_rate_box") @db.Decimal(10, 2)
  driverAllowancePerCrate Decimal? @map("driver_allowance_per_crate") @db.Decimal(10, 2)
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("freight_operational_settings")
}

model PayrollAllowanceSettings {
  id                        String   @id @default("default")
  extraMarketAllowance      Decimal? @default(30) @map("extra_market_allowance") @db.Decimal(10, 2)
  bigTruckCrateCommission   Decimal? @map("big_truck_crate_commission") @db.Decimal(10, 2)
  smallTruckCrateCommission Decimal? @map("small_truck_crate_commission") @db.Decimal(10, 2)
  bpCrateCommissionBigTruck   Decimal? @default(210) @map("bp_crate_commission_big_truck") @db.Decimal(10, 2)
  bpCrateCommissionSmallTruck Decimal? @default(190) @map("bp_crate_commission_small_truck") @db.Decimal(10, 2)
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("payroll_allowance_settings")
}

model CrateRentalRate {
  id        String   @id @default(uuid()) @db.Uuid
  crateType String   @unique @map("crate_type") @db.VarChar(10)
  isRental  Boolean  @default(true) @map("is_rental")
  rate      Decimal  @default(0) @map("rate_myr") @db.Decimal(10, 2)
  currency  String   @default("MYR") @db.VarChar(3)
  notes     String?  @db.VarChar(200)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("crate_rental_rates")
}

model GlobalCostSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(50)
  valueMyr  Decimal  @default(0) @map("value_myr") @db.Decimal(10, 2)
  label     String?  @db.VarChar(100)
  notes     String?  @db.VarChar(200)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("global_cost_settings")
}

model UnloadRate {
  id         String   @id @default(uuid()) @db.Uuid
  marketCode String   @map("market_code") @db.VarChar(10)
  crateType  String   @map("crate_type") @db.VarChar(10)
  rateMyr    Decimal  @default(0) @map("rate_myr") @db.Decimal(10, 2)
  notes      String?  @db.VarChar(200)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([marketCode, crateType])
  @@map("unload_rates")
}

model Driver {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  nickname  String?
  fullName  String?  @map("full_name")
  active    Boolean  @default(true)
  baseSalary            Decimal? @map("base_salary") @db.Decimal(10, 2)
  autoCountEmployeeCode String?  @map("autocount_employee_code")
  icNumber              String?  @unique @map("ic_number")
  epfNumber             String?  @map("epf_number")
  socsoNumber           String?  @map("socso_number")
  bankName              String?  @map("bank_name")
  bankAccount           String?  @map("bank_account")
  maritalStatus         String?  @map("marital_status")
  childCount            Int      @default(0) @map("child_count")
  createdAt DateTime @default(now()) @map("created_at")

  trucks         Truck[]
  payrollMonths  DriverPayrollMonth[]

  @@map("drivers")
}

model DriverPayrollMonth {
  id        String   @id @default(uuid()) @db.Uuid
  driverId  String   @map("driver_id") @db.Uuid
  yearMonth String   @map("year_month")
  status    String   @default("draft")
  epfEmployeeOverride   Decimal? @map("epf_employee_override") @db.Decimal(10, 2)
  epfEmployerOverride   Decimal? @map("epf_employer_override") @db.Decimal(10, 2)
  socsoEmployeeOverride Decimal? @map("socso_employee_override") @db.Decimal(10, 2)
  socsoEmployerOverride Decimal? @map("socso_employer_override") @db.Decimal(10, 2)
  eisEmployeeOverride   Decimal? @map("eis_employee_override") @db.Decimal(10, 2)
  eisEmployerOverride   Decimal? @map("eis_employer_override") @db.Decimal(10, 2)
  pcbOverride           Decimal? @map("pcb_override") @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt @map("updated_at")

  driver Driver              @relation(fields: [driverId], references: [id])
  trips  DriverPayrollTrip[]
  extras DriverPayrollExtra[]

  @@unique([driverId, yearMonth])
  @@map("driver_payroll_months")
}

model DriverPayrollTrip {
  id                    String   @id @default(uuid()) @db.Uuid
  payrollMonthId        String   @map("payroll_month_id") @db.Uuid
  dispatchOrderId       String?  @unique @map("dispatch_order_id") @db.Uuid
  date                  DateTime @db.Date
  route                 String?
  markets               String[]
  marketCount           Int      @default(0) @map("market_count")
  tripAllowance         Decimal  @default(0) @map("trip_allowance") @db.Decimal(10, 2)
  extraAllowance        Decimal  @default(0) @map("extra_allowance") @db.Decimal(10, 2)
  crateReturnCommission Decimal  @default(0) @map("crate_return_commission") @db.Decimal(10, 2)
  truckType             String?  @map("truck_type")
  notes                 String?
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at")

  payrollMonth  DriverPayrollMonth @relation(fields: [payrollMonthId], references: [id], onDelete: Cascade)
  dispatchOrder DispatchOrder?     @relation(fields: [dispatchOrderId], references: [id])
  charterTripId String?            @unique @map("charter_trip_id") @db.Uuid
  charterTrip   CharterTrip?       @relation(fields: [charterTripId], references: [id], onDelete: Cascade)

  @@map("driver_payroll_trips")
}

model DriverPayrollExtra {
  id             String   @id @default(uuid()) @db.Uuid
  payrollMonthId String   @map("payroll_month_id") @db.Uuid
  type           String
  amount         Decimal  @db.Decimal(10, 2)
  note           String?
  date           DateTime @db.Date
  createdAt      DateTime @default(now()) @map("created_at")

  payrollMonth DriverPayrollMonth @relation(fields: [payrollMonthId], references: [id], onDelete: Cascade)

  @@map("driver_payroll_extras")
}

model OperationsMonthlyCosts {
  id            String   @id @default(uuid()) @db.Uuid
  yearMonth     String   @unique @map("year_month")
  tollFee       Decimal? @map("toll_fee") @db.Decimal(12, 2)
  crateRental   Decimal? @map("crate_rental") @db.Decimal(12, 2)
  loadUnloadFee Decimal? @map("load_unload_fee") @db.Decimal(12, 2)
  lkimMaqisFee  Decimal? @map("lkim_maqis_fee") @db.Decimal(12, 2)
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("operations_monthly_costs")
}

model Truck {
  id                   String   @id @default(uuid()) @db.Uuid
  plate                String   @unique
  type                 String   @default("big")
  country              String   @default("MY")
  tollClass            String   @default("class3") @map("toll_class")
  capacityTong         Int?     @map("capacity_tong")
  defaultDriverId      String?  @map("default_driver_id") @db.Uuid
  sortOrder            Int?     @map("sort_order")
  fuelEfficiencyKmPerL Decimal? @map("fuel_efficiency_km_per_l") @db.Decimal(10, 2)
  annualMileageKm      Int?     @map("annual_mileage_km")
  active               Boolean  @default(true)

  defaultDriver          Driver?         @relation(fields: [defaultDriverId], references: [id])
  costItems              TruckCostItem[]
  inboundLines           InboundLine[]
  dispatchOrders         DispatchOrder[]
  dispatchOrdersOriginal DispatchOrder[] @relation("OriginalTruck")
  charterTrips           CharterTrip[]
  tongImports            TongImport[]
  partnerTripInvoices    PartnerTripInvoice[]

  @@map("trucks")
}

model TruckCostItem {
  id           String  @id @default(uuid()) @db.Uuid
  truckId      String  @map("truck_id") @db.Uuid
  name         String
  annualAmount Decimal @default(0) @map("annual_amount") @db.Decimal(12, 2)
  sortOrder    Int     @default(0) @map("sort_order")

  truck Truck @relation(fields: [truckId], references: [id], onDelete: Cascade)

  @@map("truck_cost_items")
}

model ThVehicle {
  id        String  @id @default(uuid()) @db.Uuid
  plate     String  @unique
  shipperId String? @map("shipper_id") @db.Uuid
  active    Boolean @default(true)

  shipper Shipper? @relation(fields: [shipperId], references: [id])

  @@map("th_vehicles")
}

// ─── Business Data ───────────────────────────────────────────────────────────

model InboundSession {
  id              String   @id @default(uuid()) @db.Uuid
  sessionNo       String?  @unique @map("session_no")
  date            DateTime @db.Date
  shipperId       String   @map("shipper_id") @db.Uuid
  thVehiclePlate  String?  @map("th_vehicle_plate")
  areaNote        String?  @map("area_note")
  pickupLocation  String?  @map("pickup_location")
  status          String   @default("confirmed") // draft | confirmed
  notes           String?
  createdById     String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  shipperCurrency   String?  @map("shipper_currency")

  shipper  Shipper       @relation(fields: [shipperId], references: [id])
  createdBy User?        @relation(fields: [createdById], references: [id])
  lines    InboundLine[]
  changeLogs InboundChangeLog[]

  @@index([date, status])
  @@map("inbound_sessions")
}

model InboundLine {
  id                 String   @id @default(uuid()) @db.Uuid
  sessionId          String   @map("session_id") @db.Uuid
  stallId            String   @map("stall_id") @db.Uuid
  tongTypeId         String   @map("tong_type_id") @db.Uuid
  quantity           Int
  isBox              Boolean  @default(false) @map("is_box")
  dispatchStatus     String   @default("unassigned") @map("dispatch_status")
  truckId            String?  @map("truck_id") @db.Uuid
  originalQuantity   Int?     @map("original_quantity")
  originalTongTypeId String?  @map("original_tong_type_id") @db.Uuid
  originalStallId    String?  @map("original_stall_id") @db.Uuid
  modifiedAt         DateTime? @map("modified_at")
  createdAt          DateTime @default(now()) @map("created_at")
  consigneeId        String?  @map("consignee_id") @db.Uuid
  paymentParty       String?  @map("payment_party")
  paymentMode        String?  @map("payment_mode")
  currency           String?
  billingCompany     String?  @map("billing_company")
  freightRate        Decimal? @map("freight_rate") @db.Decimal(10, 2)
  freightAmount      Decimal? @map("freight_amount") @db.Decimal(10, 2)
  exchangeRate       Decimal? @map("exchange_rate") @db.Decimal(10, 4)
  mcDeliveryMode         String?  @map("mc_delivery_mode")
  thirdPartyFee          Decimal? @map("third_party_fee") @db.Decimal(10, 2)
  mySegmentFreightRate   Decimal? @map("my_segment_freight_rate") @db.Decimal(10, 2)
  mySegmentFreightAmount Decimal? @map("my_segment_freight_amount") @db.Decimal(10, 2)
  thFreightRate          Decimal? @map("th_freight_rate") @db.Decimal(10, 2)
  thFreightAmount        Decimal? @map("th_freight_amount") @db.Decimal(10, 2)
  dualPaymentWtlRate     Decimal? @map("dual_payment_wtl_rate") @db.Decimal(10, 2)
  dualPaymentWtlAmount   Decimal? @map("dual_payment_wtl_amount") @db.Decimal(10, 2)
  dualPaymentWtlConsigneeId String? @map("dual_payment_wtl_consignee_id") @db.Uuid

  session          InboundSession @relation(fields: [sessionId], references: [id])
  stall            Stall          @relation(fields: [stallId], references: [id])
  consignee        Consignee?     @relation(fields: [consigneeId], references: [id])
  dualPaymentWtlConsignee Consignee? @relation("InboundLineDualPaymentWtlConsignee", fields: [dualPaymentWtlConsigneeId], references: [id])
  tongType         TongType       @relation(fields: [tongTypeId], references: [id])
  truck            Truck?         @relation(fields: [truckId], references: [id])
  originalTongType TongType?      @relation("OriginalTongType", fields: [originalTongTypeId], references: [id])
  originalStall    Stall?         @relation("OriginalStall", fields: [originalStallId], references: [id])
  dispatchLines    DispatchLine[]
  changeLogs       InboundChangeLog[]

  @@index([dispatchStatus])
  @@index([sessionId])
  @@map("inbound_lines")
}

model InboundChangeLog {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  lineId    String?  @map("line_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  field     String
  fromValue String   @map("from_value")
  toValue   String   @map("to_value")
  createdAt DateTime @default(now()) @map("created_at")

  session InboundSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  line    InboundLine?   @relation(fields: [lineId], references: [id], onDelete: SetNull)
  user    User?          @relation(fields: [userId], references: [id])

  @@map("inbound_change_logs")
}

model DispatchOrder {
  id                 String   @id @default(uuid()) @db.Uuid
  dispatchNo         String?  @unique @map("dispatch_no")
  date               DateTime @db.Date
  truckId            String   @map("truck_id") @db.Uuid
  driverName         String?  @map("driver_name")
  markets            String[]
  status             String   @default("draft")
  driverAllowanceCrates Int?  @map("driver_allowance_crates")
  driverAllowanceAmount Decimal? @map("driver_allowance_amount") @db.Decimal(10, 2)
  originalTruckId    String?  @map("original_truck_id") @db.Uuid
  originalDriverName String?  @map("original_driver_name")
  modifiedAt         DateTime? @map("modified_at")
  createdById        String?  @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")

  truck         Truck          @relation(fields: [truckId], references: [id])
  originalTruck Truck?         @relation("OriginalTruck", fields: [originalTruckId], references: [id])
  createdBy     User?          @relation(fields: [createdById], references: [id])
  lines         DispatchLine[]
  payrollTrip   DriverPayrollTrip?

  @@index([date])
  @@index([date, status])
  @@map("dispatch_orders")
}

model CharterTrip {
  id                     String   @id @default(uuid()) @db.Uuid
  charterNo              String?  @unique @map("charter_no")
  date                   DateTime @db.Date
  truckId                String   @map("truck_id") @db.Uuid
  shipperId              String?  @map("shipper_id") @db.Uuid
  stockAreaNote          String?  @map("stock_area_note")
  driverName             String?  @map("driver_name")
  cargoType              String   @map("cargo_type")
  includeBorderFees      Boolean  @default(false) @map("include_border_fees")
  charterMileageKm      Decimal  @map("charter_mileage_km") @db.Decimal(10, 2)
  charterRevenueMyr      Decimal  @map("charter_revenue_myr") @db.Decimal(12, 2)
  charterUnloadFeeMyr    Decimal? @map("charter_unload_fee_myr") @db.Decimal(10, 2)
  charterDriverSalaryMyr Decimal? @map("charter_driver_salary_myr") @db.Decimal(10, 2)
  charterOtherCostMyr    Decimal? @map("charter_other_cost_myr") @db.Decimal(10, 2)
  charterOtherCostNote   String?  @map("charter_other_cost_note")
  charterTollMyr         Decimal? @map("charter_toll_myr") @db.Decimal(10, 2)
  totalQuantity          Int?     @map("total_quantity")
  billingCompany         String   @default("haidee") @map("billing_company")
  billToCustomerName     String?  @map("bill_to_customer_name")
  computedLkimMyr        Decimal? @map("computed_lkim_myr") @db.Decimal(10, 2)
  computedCrateRentalMyr Decimal? @map("computed_crate_rental_myr") @db.Decimal(10, 2)
  charterUnloadFeeOverride Decimal? @map("charterUnloadFeeOverride") @db.Decimal(10, 2)
  charterOtherCostOverride Decimal? @map("charterOtherCostOverride") @db.Decimal(10, 2)
  charterBorderPassOverride Decimal? @map("charterBorderPassOverride") @db.Decimal(10, 2)
  charterLoadingLaborMyr Decimal? @map("charterLoadingLaborMyr") @db.Decimal(10, 2)
  createdById            String?  @map("created_by") @db.Uuid
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  truck     Truck             @relation(fields: [truckId], references: [id])
  shipper   Shipper?          @relation(fields: [shipperId], references: [id])
  createdBy User?             @relation(fields: [createdById], references: [id])
  lines      CharterTripLine[]
  extraItems CharterTripExtraItem[]
  driverPayrollTrip DriverPayrollTrip?

  @@index([date])
  @@map("charter_trips")
}

model CharterTripExtraItem {
  id            String  @id @default(uuid()) @db.Uuid
  charterTripId String  @map("charter_trip_id") @db.Uuid
  itemType      String  @map("item_type")
  amountMyr     Decimal @map("amount_myr") @db.Decimal(10, 2)
  note          String?
  sortOrder     Int     @default(0) @map("sort_order")

  charterTrip CharterTrip @relation(fields: [charterTripId], references: [id], onDelete: Cascade)

  @@index([charterTripId])
  @@map("charter_trip_extra_items")
}

model CharterTripLine {
  id            String @id @default(uuid()) @db.Uuid
  charterTripId String @map("charter_trip_id") @db.Uuid
  tongTypeId    String @map("tong_type_id") @db.Uuid
  quantity      Int

  charterTrip CharterTrip @relation(fields: [charterTripId], references: [id], onDelete: Cascade)
  tongType    TongType    @relation(fields: [tongTypeId], references: [id])

  @@index([charterTripId])
  @@map("charter_trip_lines")
}

model DispatchLine {
  id              String   @id @default(uuid()) @db.Uuid
  dispatchOrderId String   @map("dispatch_order_id") @db.Uuid
  inboundLineId   String   @map("inbound_line_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  dispatchOrder DispatchOrder @relation(fields: [dispatchOrderId], references: [id])
  inboundLine   InboundLine   @relation(fields: [inboundLineId], references: [id])

  @@index([dispatchOrderId])
  @@index([inboundLineId])
  @@map("dispatch_lines")
}

model TongImport {
  id         String    @id @default(uuid()) @db.Uuid
  date       DateTime  @db.Date
  truckId    String    @map("truck_id") @db.Uuid
  marketId   String    @map("market_id") @db.Uuid
