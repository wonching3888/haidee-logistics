# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL — copy exact strings from Supabase Dashboard → Connect
# Vercel/serverless (IPv4): Supavisor transaction pooler, port 6543
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Migrations / prisma db push: Supavisor session pooler or direct (local IPv6)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres

# --- Unified cost model (trip-cost-engine) ---
# VOUCHER_COST_MODE=legacy   # legacy | shadow | enforced (A+B voucher gate; default legacy)
# VEHICLE_ALLOC_MODE=legacy  # legacy | shadow | enforced (C vehicle leg allocation; default legacy)
